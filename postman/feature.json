    {
      "name": "1. Создание комментария (Private)",
      "item": [
        {
          "name": "1.1 Успешное создание",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const ts = Date.now();",
                  "pm.variables.set('ownerName', 'Владелец ' + ts);",
                  "pm.variables.set('ownerEmail', 'owner.' + ts + '@test.com');",
                  "pm.variables.set('categoryName', 'Категория ' + ts);",
                  "pm.variables.set('eventTitle', 'Событие ' + ts);",
                  "",
                  "// Создаём пользователя",
                  "pm.sendRequest({",
                  "    url: pm.variables.get('baseUrl') + '/admin/users',",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json' },",
                  "    body: {",
                  "        mode: 'raw',",
                  "        raw: JSON.stringify({",
                  "            name: pm.variables.get('ownerName'),",
                  "            email: pm.variables.get('ownerEmail')",
                  "        })",
                  "    }",
                  "}, (err, res) => {",
                  "    if (err) throw err;",
                  "    pm.variables.set('ownerId', res.json().id);",
                  "    ",
                  "    // Создаём категорию",
                  "    pm.sendRequest({",
                  "        url: pm.variables.get('baseUrl') + '/admin/categories',",
                  "        method: 'POST',",
                  "        header: { 'Content-Type': 'application/json' },",
                  "        body: {",
                  "            mode: 'raw',",
                  "            raw: JSON.stringify({ name: pm.variables.get('categoryName') })",
                  "        }",
                  "    }, (err2, res2) => {",
                  "        if (err2) throw err2;",
                  "        pm.variables.set('categoryId', res2.json().id);",
                  "        ",
                  "        // Создаём событие",
                  "        pm.sendRequest({",
                  "            url: pm.variables.get('baseUrl') + '/users/' + pm.variables.get('ownerId') + '/events',",
                  "            method: 'POST',",
                  "            header: { 'Content-Type': 'application/json' },",
                  "            body: {",
                  "                mode: 'raw',",
                  "                raw: JSON.stringify({",
                  "                    annotation: 'Тестовая аннотация для события',",
                  "                    category: pm.variables.get('categoryId'),",
                  "                    description: 'Тестовое описание события',",
                  "                    eventDate: '2026-12-31 15:00:00',",
                  "                    location: { lat: 55.7558, lon: 37.6176 },",
                  "                    paid: false,",
                  "                    participantLimit: 100,",
                  "                    requestModeration: true,",
                  "                    title: pm.variables.get('eventTitle')",
                  "                })",
                  "            }",
                  "        }, (err3, res3) => {",
                  "            if (err3) throw err3;",
                  "            pm.variables.set('eventId', res3.json().id);",
                  "            ",
                  "            // Публикуем событие",
                  "            pm.sendRequest({",
                  "                url: pm.variables.get('baseUrl') + '/admin/events/' + pm.variables.get('eventId'),",
                  "                method: 'PATCH',",
                  "                header: { 'Content-Type': 'application/json' },",
                  "                body: {",
                  "                    mode: 'raw',",
                  "                    raw: JSON.stringify({ stateAction: 'PUBLISH_EVENT' })",
                  "                }",
                  "            });",
                  "        });",
                  "    });",
                  "});",
                  "",
                  "pm.variables.set('newComment', 'Очень понравилось мероприятие! Обязательно приду ещё.');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Статус 201 Created', () => pm.response.to.have.status(201));",
                  "",
                  "pm.test('Комментарий содержит все поля', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json).to.have.property('text');",
                  "    pm.expect(json).to.have.property('author');",
                  "    pm.expect(json.author).to.have.property('id');",
                  "    pm.expect(json.author).to.have.property('name');",
                  "    pm.expect(json).to.have.property('eventId');",
                  "    pm.expect(json).to.have.property('createdOn');",
                  "});",
                  "",
                  "pm.test('Текст соответствует отправленному', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.text).to.equal(pm.variables.get('newComment'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"text\": \"{{newComment}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{ownerId}}/comments?eventId={{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{ownerId}}", "comments"],
              "query": [
                {
                  "key": "eventId",
                  "value": "{{eventId}}"
                }
              ]
            }
          }
        },
