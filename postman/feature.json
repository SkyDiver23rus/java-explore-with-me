              "listen": "prerequest",
              "script": {
                "exec": [
                  "const ts = Date.now();",
                  "pm.variables.set('ownerName', 'Владелец ' + ts);",
                  "pm.variables.set('ownerEmail', 'owner.' + ts + '@test.com');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Пользователь создан', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.variables.set('ownerId', json.id);",
                  "pm.variables.set('ownerName', json.name);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"{{ownerName}}\",\n    \"email\": \"{{ownerEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/users",
