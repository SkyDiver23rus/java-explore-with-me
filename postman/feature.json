      "name": "1. Private create/update/delete",
      "item": [
        {
          "name": "1.1 create comment -> 201",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const api = eval(pm.collectionVariables.get('__api__'));",
                  "const main = async () => {",
                  "  const f = await api.fixturePublishedEvent();",
                  "  pm.collectionVariables.set('userId', String(f.user.id));",
                  "  pm.collectionVariables.set('eventId', String(f.event.id));",
                  "  pm.collectionVariables.set('content', 'Очень понравилось событие, спасибо!');",
                  "};",
                  "const i = setInterval(() => {}, 1000);",
                  "setTimeout(async () => { try { await main(); } finally { clearInterval(i); } }, 50);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201', () => pm.expect(pm.response.code).to.eql(201));",
                  "const j = pm.response.json();",
                  "pm.test('dto fields', () => {",
                  "  pm.expect(j).to.have.property('id');",
                  "  pm.expect(j).to.have.property('content');",
                  "  pm.expect(j).to.have.property('author');",
                  "  pm.expect(j).to.have.property('eventId');",
                  "  pm.expect(j).to.have.property('state');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"{{content}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/:userId/comments?eventId={{eventId}}",
              "host": ["{{baseUrl}}"],
