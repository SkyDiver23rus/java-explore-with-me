{
  "info": {
    "_postman_id": "Feature_Comments",
    "name": "Explore With Me Feature_Comments",
    "description": "Коллекция с изолированными тестами для функционала комментариев.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const BASE_URL = pm.collectionVariables.get('baseUrl') || pm.variables.get('baseUrl');",
          "",
          "function req(options) {",
          "  return new Promise((resolve, reject) => {",
          "    pm.sendRequest(options, (err, res) => {",
          "      if (err) return reject(err);",
          "      resolve(res);",
          "    });",
          "  });",
          "}",
          "",
          "function uniq(prefix = 'test') {",
          "  return `${prefix}-${Date.now()}-${Math.floor(Math.random() * 10000)}`;",
          "}",
          "",
          "function assertStatus(res, expected, msg) {",
          "  pm.expect(res.code, msg || `Expected ${expected}, got ${res.code}`).to.eql(expected);",
          "}",
          "",
          "class API {",
          "  constructor(baseUrl) {",
          "    this.baseUrl = baseUrl;",
          "  }",
          "",
          "  async createUser(name = uniq('user'), email = `${uniq('user')}@test.com`) {",
          "    const res = await req({",
          "      url: `${this.baseUrl}/admin/users`,",
          "      method: 'POST',",
          "      header: { 'Content-Type': 'application/json' },",
          "      body: { mode: 'raw', raw: JSON.stringify({ name, email }) }",
          "    });",
          "    assertStatus(res, 201, 'createUser failed');",
          "    return res.json();",
          "  }",
          "",
          "  async createCategory(name = uniq('cat')) {",
          "    const res = await req({",
          "      url: `${this.baseUrl}/admin/categories`,",
          "      method: 'POST',",
          "      header: { 'Content-Type': 'application/json' },",
          "      body: { mode: 'raw', raw: JSON.stringify({ name }) }",
          "    });",
          "    assertStatus(res, 201, 'createCategory failed');",
          "    return res.json();",
          "  }",
          "",
          "  async createEvent(ownerId, categoryId, title = uniq('event')) {",
          "    const res = await req({",
          "      url: `${this.baseUrl}/users/${ownerId}/events`,",
          "      method: 'POST',",
          "      header: { 'Content-Type': 'application/json' },",
          "      body: {",
          "        mode: 'raw',",
          "        raw: JSON.stringify({",
          "          annotation: 'Test annotation',",
          "          category: categoryId,",
          "          description: 'Test description',",
          "          eventDate: '2026-12-31 15:00:00',",
          "          location: { lat: 55.7558, lon: 37.6176 },",
          "          paid: false,",
          "          participantLimit: 100,",
          "          requestModeration: true,",
          "          title",
          "        })",
          "      }",
          "    });",
          "    assertStatus(res, 201, 'createEvent failed');",
          "    return res.json();",
          "  }",
          "",
          "  async publishEvent(eventId) {",
          "    const res = await req({",
          "      url: `${this.baseUrl}/admin/events/${eventId}`,",
          "      method: 'PATCH',",
          "      header: { 'Content-Type': 'application/json' },",
          "      body: { mode: 'raw', raw: JSON.stringify({ stateAction: 'PUBLISH_EVENT' }) }",
          "    });",
          "    assertStatus(res, 200, 'publishEvent failed');",
          "    return res.json();",
          "  }",
          "",
          "  async createComment(userId, eventId, content) {",
          "    const res = await req({",
          "      url: `${this.baseUrl}/users/${userId}/comments?eventId=${eventId}`,",
          "      method: 'POST',",
          "      header: { 'Content-Type': 'application/json' },",
          "      body: { mode: 'raw', raw: JSON.stringify({ content }) }",
          "    });",
          "    assertStatus(res, 201, 'createComment failed');",
          "    return res.json();",
          "  }",
          "",
          "  async createPublishedEventFixture() {",
          "    const user = await this.createUser();",
          "    const category = await this.createCategory();",
          "    const event = await this.createEvent(user.id, category.id);",
          "    await this.publishEvent(event.id);",
          "    return { user, category, event };",
          "  }",
          "}",
          "",
          "globalThis.api = new API(BASE_URL);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Создание комментария (Private)",
      "item": [
        {
          "name": "1.1 Успешное создание",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "(async () => {",
                  "  try {",
                  "    const f = await api.createPublishedEventFixture();",
                  "    pm.variables.set('userId', f.user.id);",
                  "    pm.variables.set('eventId', f.event.id);",
                  "    pm.variables.set('commentContent', 'Очень понравилось мероприятие!');",
                  "  } catch (e) {",
                  "    throw new Error('Setup 1.1 failed: ' + e.message);",
                  "  }",
                  "})();"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Есть обязательные поля', () => {",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('content', pm.variables.get('commentContent'));",
                  "  pm.expect(json).to.have.property('author');",
                  "  pm.expect(json.author).to.have.property('id');",
                  "  pm.expect(json).to.have.property('eventId');",
                  "  pm.expect(json).to.have.property('createdOn');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"{{commentContent}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/comments?eventId={{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "comments"],
              "query": [{ "key": "eventId", "value": "{{eventId}}" }]
            }
          }
        },
