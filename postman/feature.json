    {
      "name": "1. Создание комментария (Private)",
      "item": [
        {
          "name": "1.1 Успешное создание",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const baseUrl = pm.variables.get('baseUrl');",
                  "const ts = Date.now();",
                  "",
                  "// Вспомогательные функции",
                  "async function createUser() {",
                  "    return new Promise((resolve, reject) => {",
                  "        pm.sendRequest({",
                  "            url: baseUrl + '/admin/users',",
                  "            method: 'POST',",
                  "            header: { 'Content-Type': 'application/json' },",
                  "            body: { mode: 'raw', raw: JSON.stringify({",
                  "                name: 'Test User ' + ts,",
                  "                email: `test.user.${ts}@test.com`",
                  "            })}",
                  "        }, (err, res) => {",
                  "            if (err) reject(err);",
                  "            else resolve(res.json().id);",
                  "        });",
                  "    });",
                  "}",
                  "",
                  "async function createCategory() {",
                  "    return new Promise((resolve, reject) => {",
                  "        pm.sendRequest({",
                  "            url: baseUrl + '/admin/categories',",
                  "            method: 'POST',",
                  "            header: { 'Content-Type': 'application/json' },",
                  "            body: { mode: 'raw', raw: JSON.stringify({ name: 'Test Category ' + ts })}",
                  "        }, (err, res) => {",
                  "            if (err) reject(err);",
                  "            else resolve(res.json().id);",
                  "        });",
                  "    });",
                  "}",
                  "",
                  "async function createEvent(userId, categoryId) {",
                  "    return new Promise((resolve, reject) => {",
                  "        pm.sendRequest({",
                  "            url: baseUrl + '/users/' + userId + '/events',",
                  "            method: 'POST',",
                  "            header: { 'Content-Type': 'application/json' },",
                  "            body: { mode: 'raw', raw: JSON.stringify({",
                  "                annotation: 'Test annotation for comments',",
                  "                category: categoryId,",
                  "                description: 'Test description for comments',",
                  "                eventDate: '2026-12-31 15:00:00',",
                  "                location: { lat: 55.7558, lon: 37.6176 },",
                  "                paid: false,",
                  "                participantLimit: 100,",
                  "                requestModeration: true,",
                  "                title: 'Test Event ' + ts",
                  "            })}",
                  "        }, (err, res) => {",
                  "            if (err) reject(err);",
                  "            else resolve(res.json().id);",
                  "        });",
                  "    });",
                  "}",
                  "",
                  "async function publishEvent(eventId) {",
                  "    return new Promise((resolve, reject) => {",
                  "        pm.sendRequest({",
                  "            url: baseUrl + '/admin/events/' + eventId,",
                  "            method: 'PATCH',",
                  "            header: { 'Content-Type': 'application/json' },",
                  "            body: { mode: 'raw', raw: JSON.stringify({ stateAction: 'PUBLISH_EVENT' })}",
                  "        }, (err) => {",
                  "            if (err) reject(err);",
                  "            else resolve();",
                  "        });",
                  "    });",
                  "}",
                  "",
                  "// Выполнение setup",
                  "(async function() {",
                  "    try {",
                  "        const userId = await createUser();",
                  "        pm.variables.set('userId', userId);",
                  "        ",
                  "        const categoryId = await createCategory();",
                  "        pm.variables.set('categoryId', categoryId);",
                  "        ",
                  "        const eventId = await createEvent(userId, categoryId);",
                  "        pm.variables.set('eventId', eventId);",
                  "        ",
                  "        await publishEvent(eventId);",
                  "        ",
                  "        pm.variables.set('commentContent', 'Очень понравилось мероприятие! Обязательно приду ещё.');",
                  "        console.log('Setup completed successfully');",
                  "    } catch (error) {",
                  "        console.error('Setup failed:', error);",
                  "    }",
                  "})();"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Статус 201 Created', () => pm.response.to.have.status(201));",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Комментарий содержит все поля', () => {",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json).to.have.property('content');",
                  "    pm.expect(json).to.have.property('author');",
                  "    pm.expect(json.author).to.have.property('id');",
                  "    pm.expect(json.author).to.have.property('name');",
                  "    pm.expect(json).to.have.property('eventId');",
                  "    pm.expect(json).to.have.property('createdOn');",
                  "});",
                  "",
                  "pm.test('Текст соответствует отправленному', () => {",
                  "    pm.expect(json.content).to.equal(pm.variables.get('commentContent'));",
                  "});",
                  "",
                  "// Сохраняем commentId для возможного использования",
                  "pm.variables.set('commentId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"content\": \"{{commentContent}}\" }"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/comments?eventId={{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "comments"],
              "query": [
                { "key": "eventId", "value": "{{eventId}}" }
              ]
            }
          }
        },
