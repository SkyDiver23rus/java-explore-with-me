                  "                    category: pm.variables.get('categoryId'),",
                  "                    description: 'Тестовое описание события',",
                  "                    eventDate: '2026-12-31 15:00:00',",
                  "                    location: { lat: 55.7558, lon: 37.6176 },",
                  "                    paid: false,",
                  "                    participantLimit: 100,",
                  "                    requestModeration: true,",
                  "                    title: pm.variables.get('eventTitle')",
                  "                })",
                  "            }",
                  "        }, (err3, res3) => {",
                  "            if (err3) throw err3;",
                  "            pm.variables.set('eventId', res3.json().id);",
                  "            ",
                  "            // Публикуем событие",
                  "            pm.sendRequest({",
                  "                url: pm.variables.get('baseUrl') + '/admin/events/' + pm.variables.get('eventId'),",
                  "                method: 'PATCH',",
                  "                header: { 'Content-Type': 'application/json' },",
                  "                body: {",
                  "                    mode: 'raw',",
                  "                    raw: JSON.stringify({ stateAction: 'PUBLISH_EVENT' })",
                  "                }",
                  "            });",
                  "        });",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Статус 201 Created', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Длина текста = 350 символов', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.text.length).to.equal(350);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"text\": \"{{commentText}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{ownerId}}/comments?eventId={{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{ownerId}}", "comments"],
              "query": [
                {
                  "key": "eventId",
                  "value": "{{eventId}}"
                }
              ]
            }
          }
        },
        {
          "name": "1.3 Пустой текст",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
