{
  "info": {
    "_postman_id": "Feature_Comments",
    "name": "Explore With Me Feature_Comments",
    "description": "Коллекция с изолированными тестами для функционала комментариев.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const helper = [",
          "\"(() => {\",",
          "\"  const BASE_URL = pm.collectionVariables.get('baseUrl') || 'http://localhost:8080';\",",
          "\"  const send = (opt) => new Promise((resolve, reject) => pm.sendRequest(opt, (e, r) => e ? reject(e) : resolve(r)));\",",
          "\"  const uniq = (p='t') => `${p}-${Date.now()}-${Math.floor(Math.random()*10000)}`;\",",
          "\"  const ok = (res, code, msg) => pm.expect(res.code, msg || `Expected ${code}, got ${res.code}`).to.eql(code);\",",
          "\"\",",
          "\"  class API {\",",
          "\"    async createUser() {\",",
          "\"      const body = { name: uniq('user'), email: `${uniq('mail')}@test.com` };\",",
          "\"      const res = await send({ url: BASE_URL + '/admin/users', method: 'POST', header: { 'Content-Type': 'application/json' }, body: { mode: 'raw', raw: JSON.stringify(body) } });\",",
          "\"      ok(res, 201, 'createUser failed');\",",
          "\"      return res.json();\",",
          "\"    }\",",
          "\"\",",
          "\"    async createCategory() {\",",
          "\"      const body = { name: uniq('cat') };\",",
          "\"      const res = await send({ url: BASE_URL + '/admin/categories', method: 'POST', header: { 'Content-Type': 'application/json' }, body: { mode: 'raw', raw: JSON.stringify(body) } });\",",
          "\"      ok(res, 201, 'createCategory failed');\",",
          "\"      return res.json();\",",
          "\"    }\",",
          "\"\",",
          "\"    async createEvent(ownerId, categoryId) {\",",
          "\"      const body = {\",",
          "\"        annotation: 'Аннотация комментариев: валидная длина больше двадцати символов',\",",
          "\"        category: categoryId,\",",
          "\"        description: 'Описание события для тестов комментариев, валидной длины и структуры',\",",
          "\"        eventDate: '2030-12-31 15:00:00',\",",
          "\"        location: { lat: 55.7558, lon: 37.6176 },\",",
          "\"        paid: false,\",",
          "\"        participantLimit: 100,\",",
          "\"        requestModeration: true,\",",
          "\"        title: uniq('event')\",",
          "\"      };\",",
          "\"      const res = await send({ url: BASE_URL + '/users/' + ownerId + '/events', method: 'POST', header: { 'Content-Type': 'application/json' }, body: { mode: 'raw', raw: JSON.stringify(body) } });\",",
          "\"      ok(res, 201, 'createEvent failed');\",",
          "\"      return res.json();\",",
          "\"    }\",",
          "\"\",",
          "\"    async publishEvent(eventId) {\",",
          "\"      const res = await send({ url: BASE_URL + '/admin/events/' + eventId, method: 'PATCH', header: { 'Content-Type': 'application/json' }, body: { mode: 'raw', raw: JSON.stringify({ stateAction: 'PUBLISH_EVENT' }) } });\",",
          "\"      ok(res, 200, 'publishEvent failed');\",",
          "\"      return res.json();\",",
          "\"    }\",",
          "\"\",",
          "\"    async createComment(userId, eventId, content) {\",",
          "\"      const res = await send({ url: BASE_URL + '/users/' + userId + '/comments?eventId=' + eventId, method: 'POST', header: { 'Content-Type': 'application/json' }, body: { mode: 'raw', raw: JSON.stringify({ content }) } });\",",
          "\"      ok(res, 201, 'createComment failed');\",",
          "\"      return res.json();\",",
          "\"    }\",",
          "\"\",",
          "\"    async fixturePublishedEvent() {\",",
          "\"      const user = await this.createUser();\",",
          "\"      const category = await this.createCategory();\",",
          "\"      const event = await this.createEvent(user.id, category.id);\",",
          "\"      await this.publishEvent(event.id);\",",
          "\"      return { user, category, event };\",",
          "\"    }\",",
          "\"  }\",",
          "\"\",",
          "\"  return new API();\",",
          "\"})()\"",
          "];",
          "pm.collectionVariables.set('__api__', helper.join('\\n'));"
        ]
      }
    }
  ],
  "item": [
